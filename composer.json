{
	"name": "duon/registry",
	"description": "A PSR-11 compatible dependency injection library",
	"keywords": [
		"di",
		"dependency injection",
		"container",
		"ioc",
		"psr-11",
		"psr11"
	],
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Thomas Ernst",
			"email": "duon@ebenefuenf.de"
		}
	],
	"homepage": "https://duon.run/registry",
	"require": {
		"php": "^8.5",
		"duon/wire": "^0.1",
		"psr/container": "^2.0"
	},
	"require-dev": {
		"duon/dev": "^2.5"
	},
	"autoload": {
		"psr-4": {
			"Duon\\Registry\\": "src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Duon\\Registry\\Tests\\": "tests"
		},
		"files": [
			"tests/Fixtures/globalTestSymbols.php"
		]
	},
	"scripts": {
		"test": [
			"composer docstest",
			"./vendor/bin/phpunit --testdox --no-coverage --colors=always"
		],
		"check": "./vendor/bin/psalm --no-cache",
		"check-github": "./vendor/bin/psalm --output-format=github --shepherd",
		"lint": "./vendor/bin/phpcs -s -p src tests",
		"coverage": [
			"./vendor/bin/phpunit --testdox --coverage-text --coverage-php=coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer coverage/cover.php"
		],
		"ci": [
			"composer docstest",
			"composer coverage",
			"composer check",
			"composer lint"
		],
		"github": [
			"composer docstest",
			"composer coverage",
			"composer check-github",
			"composer lint"
		],
		"docstest": "./vendor/bin/docs-test-runner ./docs/code"
	}
}
