{
	"name": "duon/container",
	"description": "A PSR-11 compatible dependency injection library",
	"keywords": [
		"di",
		"dependency injection",
		"container",
		"ioc",
		"psr-11",
		"psr11"
	],
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@duon.run"
		}
	],
	"homepage": "https://duon.run/container",
	"require": {
		"php": "^8.5",
		"duon/wire": "dev-main",
		"psr/container": "^2.0"
	},
	"require-dev": {
		"duon/dev": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"Duon\\Container\\": "src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Duon\\Container\\Tests\\": "tests"
		}
	},
	"scripts": {
		"test": "./vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"docstest": "./vendor/bin/docs-test-runner ./docs/code",
		"types": "./vendor/bin/psalm --no-cache",
		"mdlint": "markdownlint-cli2 README.md CHANGELOG.md LICENSE.md docs/",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"coverage": [
			"./vendor/bin/phpunit --testdox --path-coverage --coverage-text --coverage-php=.coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer .coverage/cover.php"
		],
		"ci": [
			"composer lint",
			"composer docstest",
			"composer coverage",
			"composer types",
			"composer mdlint"
		]
	}
}
