{
	"name": "duon/container",
	"description": "A PSR-11 compatible dependency injection library",
	"keywords": [
		"di",
		"dependency injection",
		"container",
		"ioc",
		"psr-11",
		"psr11"
	],
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@duon.run"
		}
	],
	"homepage": "https://duon.run/container",
	"require": {
		"php": "^8.5",
		"duon/wire": "dev-main",
		"psr/container": "^2.0"
	},
	"require-dev": {
		"duon/dev": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"Duon\\Container\\": "src"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Duon\\Container\\Tests\\": "tests"
		},
		"files": [
			"tests/Fixtures/globalTestSymbols.php"
		]
	},
	"scripts": {
		"test": [
			"composer docstest",
			"./vendor/bin/phpunit --testdox --no-coverage --colors=always"
		],
		"types": "./vendor/bin/psalm --no-cache",
		"coverage": [
			"./vendor/bin/phpunit --testdox --coverage-text --coverage-php=coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer coverage/cover.php"
		],
		"ci": [
			"composer docstest",
			"composer coverage",
			"composer types"
		],
		"docstest": "./vendor/bin/docs-test-runner ./docs/code"
	}
}
